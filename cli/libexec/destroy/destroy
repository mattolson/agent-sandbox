#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../../lib/logging.bash
source "$AGB_LIBDIR/logging.bash"
# shellcheck source=../../lib/constants.bash
source "$AGB_LIBDIR/constants.bash"
# shellcheck source=../../lib/cli-compose.bash
source "$AGB_LIBDIR/cli-compose.bash"
# shellcheck source=../../lib/devcontainer.bash
source "$AGB_LIBDIR/devcontainer.bash"
# shellcheck source=../../lib/path.bash
source "$AGB_LIBDIR/path.bash"
# shellcheck source=../../lib/select.bash
source "$AGB_LIBDIR/select.bash"

destroy_can_resolve_compose_stack() {
	local repo_root=$1
	local legacy_project_compose="$repo_root/$AGB_PROJECT_DIR/docker-compose.yml"
	local legacy_devcontainer_compose="$repo_root/.devcontainer/docker-compose.yml"

	cli_layered_compose_initialized "$repo_root" ||
		devcontainer_centralized_runtime_initialized "$repo_root" ||
		[[ -f "$legacy_project_compose" ]] ||
		[[ -f "$legacy_devcontainer_compose" ]]
}

destroy() {
	local repo_root
	repo_root="$(find_repo_root)"

	case "${1:-}" in
	-f | --force)
		;;
	"")
		echo "This will stop containers, remove volumes, and delete .devcontainer and $AGB_PROJECT_DIR directories." |
			warning
		if [[ "$(select_yes_no "Continue?")" == "false" ]]
		then
			echo "Aborting" | warning
			return 0
		fi
		;;
	*)
		echo "$0: unknown parameter: $1" >&2
		return 1
		;;
	esac

	echo "Stopping containers" | warning
	if destroy_can_resolve_compose_stack "$repo_root"
	then
		if cli_layered_compose_initialized "$repo_root" || devcontainer_centralized_runtime_initialized "$repo_root"
		then
			if ! "$AGB_LIBDIR/run-compose" down --volumes
			then
				echo "Could not stop containers from the current compose layout. Continuing with filesystem cleanup." | warning
			fi
		else
			local compose_file
			compose_file="$(find_compose_file)"
			if ! docker compose -f "$compose_file" down --volumes
			then
				echo "Could not stop containers from the legacy compose layout. Continuing with filesystem cleanup." | warning
			fi
		fi
	else
		echo "No compose stack found. Skipping container shutdown." | warning
	fi

	local project_dir="$repo_root/$AGB_PROJECT_DIR"
	if [[ -d "$project_dir" ]]
	then
		echo "Removing $project_dir" | warning
		rm -rf "$project_dir"
	fi

	local devcontainer_dir="$repo_root/.devcontainer"
	if [[ -d "$devcontainer_dir" ]]
	then
		echo "Removing $devcontainer_dir" | warning
		rm -rf "$devcontainer_dir"
	fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
	destroy "$@"
fi
