#!/usr/bin/env bash
set -euo pipefail

if [[ $# -gt 0 ]]
then
	echo "agentbox policy config does not accept arguments" >&2
	exit 1
fi

AGENTBOX_RUNTIME_COMMAND_NAME="policy config" AGENTBOX_SKIP_RUNTIME_SYNC=1 exec \
	"$AGB_LIBDIR/run-compose" run --rm --no-deps -T --entrypoint /usr/local/bin/render-policy proxy
