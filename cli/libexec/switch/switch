#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../../lib/logging.bash
source "$AGB_LIBDIR/logging.bash"
# shellcheck source=../../lib/path.bash
source "$AGB_LIBDIR/path.bash"
# shellcheck source=../../lib/agent.bash
source "$AGB_LIBDIR/agent.bash"
# shellcheck source=../../lib/cli-compose.bash
source "$AGB_LIBDIR/cli-compose.bash"
# shellcheck source=../../lib/devcontainer.bash
source "$AGB_LIBDIR/devcontainer.bash"
# shellcheck source=../../lib/legacy-layout.bash
source "$AGB_LIBDIR/legacy-layout.bash"

switch() {
	local agent=""

	while [[ $# -gt 0 ]]
	do
		case "$1" in
		--agent)
			agent="$2"
			shift 2
			;;
		*)
			echo "Unknown option: $1" | error
			return 1
			;;
		esac
	done

	local repo_root
	repo_root="$(find_repo_root)"

	if ! agent_sandbox_initialized "$repo_root"
	then
		echo "agent-sandbox is not initialized at $repo_root. Run 'agentbox init' first." | error
		return 1
	fi

	if [[ -n "$agent" ]]
	then
		validate_agent "$agent" || return 1
	fi

	abort_if_unsupported_legacy_layout "$repo_root" "switch" "$agent" || return 1

	if [[ -z "$agent" ]]
	then
		agent="$(select_agent)"
	fi

	local current_agent=""
	if current_agent="$(read_active_agent "$repo_root" 2>/dev/null)" &&
		[[ "$current_agent" == "$agent" ]]
	then
		local refreshed=false
		if devcontainer_centralized_runtime_initialized "$repo_root"
		then
			ensure_devcontainer_runtime_files "$repo_root" "$agent"
			refreshed=true
		fi

		if cli_layered_compose_initialized "$repo_root" && ! devcontainer_centralized_runtime_initialized "$repo_root"
		then
			ensure_cli_agent_runtime_files "$repo_root" "$agent"
			refreshed=true
		fi

		if [[ "$refreshed" == "true" ]]
		then
			echo "Active agent is already '$agent'. Refreshed layered runtime files." | info
		else
			echo "Active agent is already '$agent'. No changes made." | info
		fi
		return 0
	fi

	local runtime_running=""
	if [[ -n "$current_agent" ]]
	then
		runtime_running=$("$AGB_LIBDIR/run-compose" ps --status running --quiet 2>/dev/null) || true
	fi

	if devcontainer_centralized_runtime_initialized "$repo_root"
	then
		ensure_devcontainer_runtime_files "$repo_root" "$agent" false
	fi

	if cli_layered_compose_initialized "$repo_root" && ! devcontainer_centralized_runtime_initialized "$repo_root"
	then
		ensure_cli_agent_runtime_files "$repo_root" "$agent"
	fi

	if [[ -n "$runtime_running" ]]
	then
		echo "Active agent set to '$agent'. Restarting containers to apply the switch..." | info
		"$AGB_LIBDIR/run-compose" down
		write_active_agent "$repo_root" "$agent"
		"$AGB_LIBDIR/run-compose" up -d
	else
		write_active_agent "$repo_root" "$agent"
		echo "Active agent set to '$agent'." | info
	fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
	switch "$@"
fi
