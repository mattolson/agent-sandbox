#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../../lib/compat.bash
source "$AGB_LIBDIR/compat.bash"
# shellcheck source=../../lib/logging.bash
source "$AGB_LIBDIR/logging.bash"
# shellcheck source=../../lib/constants.bash
source "$AGB_LIBDIR/constants.bash"
# shellcheck source=../../lib/agent.bash
source "$AGB_LIBDIR/agent.bash"
# shellcheck source=../../lib/cli-compose.bash
source "$AGB_LIBDIR/cli-compose.bash"
# shellcheck source=../../lib/devcontainer.bash
source "$AGB_LIBDIR/devcontainer.bash"
# shellcheck source=../../lib/select.bash
source "$AGB_LIBDIR/select.bash"
# shellcheck source=../../lib/path.bash
source "$AGB_LIBDIR/path.bash"

# Opens the network policy file in the default editor. If the file is modified,
# automatically restarts the proxy service (only if docker compose is running).
#
legacy_policy_file_matches() {
	local repo_root=$1
	local mode=$2
	local agent=$3
	local mode_pattern="${mode:-*}"
	local agent_pattern="${agent:-*}"
	local policy_files=()

	mapfile -t policy_files < <(compgen -G "$repo_root/$AGB_PROJECT_DIR/policy-$mode_pattern-$agent_pattern.yaml" 2>/dev/null | sort)
	if [[ ${#policy_files[@]} -gt 0 ]]
	then
		printf '%s\n' "${policy_files[@]}"
	fi
}

policy() {
	local repo_root
	repo_root="$(find_repo_root)"

	local mode=""
	local agent=""
	local policy_file=""
	local restart_scope="active"

	while [[ $# -gt 0 ]]
	do
		case "$1" in
		--mode)
			mode="$2"
			shift 2
			;;
		--agent)
			agent="$2"
			shift 2
			;;
		*)
			echo "Unknown argument: $1" | error
			return 1
			;;
		esac
	done

	if cli_layered_compose_initialized "$repo_root" || devcontainer_centralized_runtime_initialized "$repo_root"
	then
		scaffold_cli_shared_policy_if_missing "$repo_root"

		if [[ -n "$agent" ]]
		then
			validate_agent "$agent" || return 1
			migrate_cli_legacy_policy_file "$repo_root" "$agent"
			ensure_cli_policy_file "$repo_root" "$agent"
			policy_file="$(cli_user_agent_policy_file "$repo_root" "$agent")"

			local active_agent=""
			active_agent="$(read_active_agent "$repo_root" 2>/dev/null)" || true
			if [[ -n "$active_agent" ]] && [[ "$active_agent" != "$agent" ]]
			then
				restart_scope="inactive-agent"
			fi
		else
			policy_file="$(cli_shared_policy_file "$repo_root")"
		fi
	else
		local policy_files=()
		mapfile -t policy_files < <(legacy_policy_file_matches "$repo_root" "$mode" "$agent")
		if [[ ${#policy_files[@]} -eq 0 ]]
		then
			local mode_pattern="${mode:-*}"
			local agent_pattern="${agent:-*}"
			echo "No policy file found matching pattern: $repo_root/$AGB_PROJECT_DIR/policy-$mode_pattern-$agent_pattern.yaml" | error
			return 1
		fi

		if [[ ${#policy_files[@]} -gt 1 ]]
		then
			echo "Multiple policy files found matching pattern:" | warning
			printf '  %s\n' "${policy_files[@]}" | warning
			echo "Using: ${policy_files[0]}" | warning
		fi

		policy_file="${policy_files[0]}"
	fi

	local mtime_before
	mtime_before=$(get_file_mtime "$policy_file")

	open_editor "$policy_file"

	local mtime_after
	mtime_after=$(get_file_mtime "$policy_file")

	if [[ "$mtime_after" != "$mtime_before" ]]
	then
		if [[ "$restart_scope" == "inactive-agent" ]]
		then
			echo "Policy file was modified for inactive agent '$agent'. Changes apply after 'agentbox switch --agent $agent'." | warning
			return 0
		fi

		local proxy_status
		proxy_status=$("$AGB_LIBDIR/run-compose" ps proxy --status running --quiet 2>/dev/null) || true
		if [[ -n "$proxy_status" ]]
		then
			echo "Policy file was modified. Restarting proxy service..." | info
			exec "$AGB_LIBDIR/run-compose" restart proxy
		else
			echo "Policy file was modified, but proxy service is not running. Skipping restart." | warning
		fi
	else
		echo "Policy file unchanged. Skipping restart." | warning
	fi
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
	policy "$@"
fi
