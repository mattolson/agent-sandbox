#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../../lib/logging.bash
source "$AGB_LIBDIR/logging.bash"
# shellcheck source=../../lib/devcontainer.bash
source "$AGB_LIBDIR/devcontainer.bash"

# Sets up a Devcontainer configuration for an agent.
# Creates managed devcontainer files plus user-owned extension points.
# Args:
#   --project-path - Path to the project directory
#   --agent - The agent name (e.g., "claude")
#   --ide - The IDE name (e.g., "vscode", "jetbrains", "none")
devcontainer() {
	local project_path=""
	local agent=""
	local ide=""
	local name=""

	while [[ $# -gt 0 ]]
	do
		case $1 in
		--project-path)
			project_path="$2"
			shift 2
			;;
		--agent)
			agent="$2"
			shift 2
			;;
		--ide)
			ide="$2"
			shift 2
			;;
		--name)
			name="$2"
			shift 2
			;;
		*)
			echo "Unknown option: $1" | error
			return 1
			;;
		esac
	done

	: "${project_path?Missing required parameter: --project-path}"
	: "${agent?Missing required parameter: --agent}"
	: "${ide?Missing required parameter: --ide}"

	validate_devcontainer_ide "$ide"

	local project_name
	project_name="${name:-$(derive_project_name "$project_path" "devcontainer")}"

	initialize_devcontainer_sidecar_layout "$project_path" "$agent" "$ide" "$project_name"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
	devcontainer "$@"
fi
