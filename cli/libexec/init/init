#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../../lib/logging.bash
source "$AGB_LIBDIR/logging.bash"
# shellcheck source=../../lib/require.bash
source "$AGB_LIBDIR/require.bash"
# shellcheck source=../../lib/select.bash
source "$AGB_LIBDIR/select.bash"
# shellcheck source=../../lib/constants.bash
source "$AGB_LIBDIR/constants.bash"
# shellcheck source=../../lib/path.bash
source "$AGB_LIBDIR/path.bash"
# shellcheck source=../../lib/agent.bash
source "$AGB_LIBDIR/agent.bash"
# shellcheck source=../../lib/cli-compose.bash
source "$AGB_LIBDIR/cli-compose.bash"
# shellcheck source=../../lib/devcontainer.bash
source "$AGB_LIBDIR/devcontainer.bash"
# shellcheck source=../../lib/legacy-layout.bash
source "$AGB_LIBDIR/legacy-layout.bash"

# Initializes agent-sandbox for a project.
# Prompts for any options not provided via flags.
# Args:
#   --agent - Agent type (claude, codex, copilot)
#   --mode - Setup mode (cli, devcontainer)
#   --ide - IDE for devcontainer mode (vscode, jetbrains, none)
#   --name - Project name for Docker Compose
#   --path - Project directory path
#   --batch - Disable prompts and require explicit mode-selection flags
print_init_view_commands_hint() {
	echo "Use 'agentbox policy config' to view the effective policy and 'agentbox compose config' to view the effective compose stack." | info
}

init() {
	local name=""
	local project_path=""
	local agent=""
	local mode=""
	local ide=""
	local batch=false

	while [[ $# -gt 0 ]]
	do
		case $1 in
		--name)
			name="$2"
			shift 2
			;;
		--path)
			project_path="$2"
			shift 2
			;;
		--agent)
			agent="$2"
			shift 2
			;;
		--mode)
			mode="$2"
			shift 2
			;;
		--ide)
			ide="$2"
			shift 2
			;;
		--batch)
			batch=true
			shift
			;;
		*)
			echo "Unknown option: $1" | error
			return 1
			;;
		esac
	done

	if [[ -z "$project_path" ]]
	then
		project_path="."
	fi

	if [[ ! -d "$project_path" ]]
	then
		echo "Directory does not exist: $project_path" | error
		return 1
	fi
	project_path=$(cd "$project_path" && pwd)

	if [[ -n "$agent" ]] && ! validate_agent "$agent"
	then
		return 1
	fi

	local available_modes=(cli devcontainer)
	if [[ -n "$mode" ]] && [[ ! " ${available_modes[*]} " =~ [[:space:]]${mode}[[:space:]] ]]
	then
		echo "Invalid mode: $mode (expected: ${available_modes[*]})" | error
		return 1
	fi

	local available_ides=(vscode jetbrains none)
	if [[ -n "$ide" ]] && [[ ! " ${available_ides[*]} " =~ [[:space:]]${ide}[[:space:]] ]]
	then
		echo "Invalid IDE: $ide (expected: ${available_ides[*]})" | error
		return 1
	fi

	abort_if_unsupported_legacy_layout "$project_path" "init" "$agent" "$mode" "$ide" || return 1

	echo "Configuring project at: $project_path" | info

	# Calculate the default base name to display (without mode suffix)
	local default_base_name
	default_base_name=$(derive_base_project_name "$project_path")

	if [[ -z "$name" ]]
	then
		if [[ "$batch" == "true" ]]
		then
			name="$default_base_name"
		else
			name=$(read_line "Project name [$default_base_name]:")
		fi
	fi

	# If user didn't provide a name, use the default
	if [[ -z "$name" ]]
	then
		name="$default_base_name"
	fi

	if [[ -z "$agent" ]]
	then
		if [[ "$batch" == "true" ]]
		then
			echo "Missing required option in batch mode: --agent (expected: $(supported_agents_display))" | error
			return 1
		fi
		agent=$(select_agent)
	fi

	if [[ -z "$mode" ]]
	then
		if [[ "$batch" == "true" ]]
		then
			echo "Missing required option in batch mode: --mode (expected: ${available_modes[*]})" | error
			return 1
		fi
		mode=$(select_option "Select mode:" "${available_modes[@]}")
	elif [[ ! " ${available_modes[*]} " =~ [[:space:]]${mode}[[:space:]] ]]
	then
		echo "Invalid mode: $mode (expected: ${available_modes[*]})" | error
		return 1
	fi

	case "$mode" in
	cli)
		require yq
		cli \
			--project-path "$project_path" \
			--agent "$agent" \
			--name "$name"
		write_active_agent "$project_path" "$agent" "$name"
		print_init_view_commands_hint
		;;
	devcontainer)
		local available_ides=(vscode jetbrains none)
		if [[ -z "$ide" ]]
		then
			if [[ "$batch" == "true" ]]
			then
				echo "Missing required option in batch mode: --ide (expected: ${available_ides[*]})" | error
				return 1
			fi
			ide=$(select_option "Select IDE:" "${available_ides[@]}")
		fi

		require yq
		devcontainer \
			--project-path "$project_path" \
			--agent "$agent" \
			--ide "$ide" \
			--name "$name"
		write_devcontainer_state "$project_path" "$agent" "$ide" "$name"
		print_init_view_commands_hint
		;;
	*)
		echo "Invalid mode selected: $mode" | error
		return 1
		;;
	esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
	init "$@"
fi
