#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../../lib/logging.bash
source "$AGB_LIBDIR/logging.bash"
# shellcheck source=../../lib/require.bash
source "$AGB_LIBDIR/require.bash"
# shellcheck source=../../lib/select.bash
source "$AGB_LIBDIR/select.bash"
# shellcheck source=../../lib/constants.bash
source "$AGB_LIBDIR/constants.bash"
# shellcheck source=../../lib/path.bash
source "$AGB_LIBDIR/path.bash"

# Initializes agent-sandbox for a project.
# Prompts for any options not provided via flags.
# Args:
#   --agent - Agent type (claude, copilot, codex)
#   --mode - Setup mode (cli, devcontainer)
#   --ide - IDE for devcontainer mode (vscode, jetbrains, none)
#   --name - Project name for Docker Compose
#   --path - Project directory path
#   --batch - Disable prompts and require explicit mode-selection flags
review_generated_file() {
	local label="$1"
	local file="$2"
	local batch="${3:-false}"

	if [[ "$batch" == "true" ]]
	then
		return 0
	fi

	local should_review
	should_review=$(select_yes_no "Review the generated $label file at $file?")
	if [[ "$should_review" == "true" ]]
	then
		open_editor "$file"
	fi
}

init() {
	local name=""
	local project_path=""
	local agent=""
	local mode=""
	local ide=""
	local batch=false
	local name_provided_via_flag=false

	while [[ $# -gt 0 ]]
	do
		case $1 in
		--name)
			name="$2"
			name_provided_via_flag=true
			shift 2
			;;
		--path)
			project_path="$2"
			shift 2
			;;
		--agent)
			agent="$2"
			shift 2
			;;
		--mode)
			mode="$2"
			shift 2
			;;
		--ide)
			ide="$2"
			shift 2
			;;
		--batch)
			batch=true
			shift
			;;
		*)
			echo "Unknown option: $1" | error
			return 1
			;;
		esac
	done

	if [[ -z "$project_path" ]]
	then
		project_path="."
	fi

	if [[ ! -d "$project_path" ]]
	then
		echo "Directory does not exist: $project_path" | error
		return 1
	fi
	project_path=$(cd "$project_path" && pwd)

	echo "Configuring project at: $project_path" | info

	# Calculate the default base name to display (without mode suffix)
	local default_base_name
	default_base_name=$(derive_base_project_name "$project_path")

	if [[ -z "$name" ]]
	then
		if [[ "$batch" == "true" ]]
		then
			name="$default_base_name"
		else
			name=$(read_line "Project name [$default_base_name]:")
		fi
	fi

	# If user didn't provide a name, use the default
	if [[ -z "$name" ]]
	then
		name="$default_base_name"
	fi

	local available_agents=(claude copilot codex)
	if [[ -z "$agent" ]]
	then
		if [[ "$batch" == "true" ]]
		then
			echo "Missing required option in batch mode: --agent (expected: ${available_agents[*]})" | error
			return 1
		fi
		agent=$(select_option "Select agent:" "${available_agents[@]}")
	elif [[ ! " ${available_agents[*]} " =~ [[:space:]]${agent}[[:space:]] ]]
	then
		echo "Invalid agent: $agent (expected: ${available_agents[*]})" | error
		return 1
	fi

	local available_modes=(cli devcontainer)
	if [[ -z "$mode" ]]
	then
		if [[ "$batch" == "true" ]]
		then
			echo "Missing required option in batch mode: --mode (expected: ${available_modes[*]})" | error
			return 1
		fi
		mode=$(select_option "Select mode:" "${available_modes[@]}")
	elif [[ ! " ${available_modes[*]} " =~ [[:space:]]${mode}[[:space:]] ]]
	then
		echo "Invalid mode: $mode (expected: ${available_modes[*]})" | error
		return 1
	fi

	# Apply mode suffix to the name (only if name wasn't provided via --name flag)
	if [[ "$name_provided_via_flag" == false ]]
	then
		name=$(apply_mode_suffix "$name" "$mode")
	fi

	local policy_file="$AGB_PROJECT_DIR/policy-$mode-$agent.yaml"

	case "$mode" in
	cli)
		require yq
		policy "$project_path/$policy_file" "$agent"
		cli \
			--policy-file "$policy_file" \
			--project-path "$project_path" \
			--agent "$agent" \
			--name "$name"
		review_generated_file "policy" "$project_path/$policy_file" "$batch"
		review_generated_file "compose" "$project_path/$AGB_PROJECT_DIR/docker-compose.yml" "$batch"
		;;
	devcontainer)
		local available_ides=(vscode jetbrains none)
		if [[ -z "$ide" ]]
		then
			if [[ "$batch" == "true" ]]
			then
				echo "Missing required option in batch mode: --ide (expected: ${available_ides[*]})" | error
				return 1
			fi
			ide=$(select_option "Select IDE:" "${available_ides[@]}")
		elif [[ ! " ${available_ides[*]} " =~ [[:space:]]${ide}[[:space:]] ]]
		then
			echo "Invalid IDE: $ide (expected: ${available_ides[*]})" | error
			return 1
		fi

		local services=("$agent")
		if [[ "$ide" != "none" ]]
		then
			services+=("$ide")
		fi

		require yq
		policy "$project_path/$policy_file" "${services[@]}"
		devcontainer \
			--policy-file "$policy_file" \
			--project-path "$project_path" \
			--agent "$agent" \
			--ide "$ide" \
			--name "$name"
		review_generated_file "policy" "$project_path/$policy_file" "$batch"
		review_generated_file "compose" "$project_path/.devcontainer/docker-compose.yml" "$batch"
		;;
	*)
		echo "Invalid mode selected: $mode" | error
		return 1
		;;
	esac
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
	init "$@"
fi
