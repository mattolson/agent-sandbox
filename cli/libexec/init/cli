#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../../lib/logging.bash
source "$AGB_LIBDIR/logging.bash"
# shellcheck source=../../lib/cli-compose.bash
source "$AGB_LIBDIR/cli-compose.bash"

# Sets up CLI mode layered docker compose configuration for an agent.
# Args:
#   --project-path - Path to the project directory
#   --agent - The agent name (e.g., "claude")
#   --name - Project name for Docker Compose
cli() {
	local project_path=""
	local agent=""
	local name=""

	while [[ $# -gt 0 ]]
	do
		case $1 in
		--project-path)
			project_path="$2"
			shift 2
			;;
		--agent)
			agent="$2"
			shift 2
			;;
		--name)
			name="$2"
			shift 2
			;;
		*)
			echo "Unknown option: $1" | error
			return 1
			;;
		esac
	done

	: "${project_path?Missing required parameter: --project-path}"
	: "${agent?Missing required parameter: --agent}"

	project_path=$(cd "$project_path" && pwd)

	local project_name
	project_name="${name:-$(derive_project_name "$project_path" "cli")}"

	initialize_cli_layered_layout "$project_path" "$agent" "$project_name"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
	cli "$@"
fi
