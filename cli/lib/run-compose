#!/usr/bin/env bash
set -euo pipefail

# shellcheck source=../../lib/require.bash
source "$AGB_LIBDIR/require.bash"
# shellcheck source=../../lib/cli-compose.bash
source "$AGB_LIBDIR/cli-compose.bash"
# shellcheck source=../../lib/devcontainer.bash
source "$AGB_LIBDIR/devcontainer.bash"
# shellcheck source=../../lib/legacy-layout.bash
source "$AGB_LIBDIR/legacy-layout.bash"
# shellcheck source=../../lib/path.bash
source "$AGB_LIBDIR/path.bash"

# Helper that automatically locates the docker compose files
# All arguments are passed to docker compose
compose_command_requires_runtime_sync() {
	case "${AGENTBOX_SKIP_RUNTIME_SYNC:-}" in
	1 | true)
		return 1
		;;
	esac

	case "${1:-}" in
	up | run | create | restart | start)
		return 0
		;;
	*)
		return 1
		;;
	esac
}

compose() {
	local repo_root
	repo_root="$(find_repo_root)"

	local command_name="${AGENTBOX_RUNTIME_COMMAND_NAME:-runtime command}"
	abort_if_unsupported_legacy_layout "$repo_root" "$command_name" || return 1

	require docker

	local compose_files=()
	local sync_runtime=false
	if compose_command_requires_runtime_sync "${1:-}"
	then
		sync_runtime=true
	fi

	if devcontainer_centralized_runtime_initialized "$repo_root"
	then
		local active_agent
		active_agent="$(read_active_agent "$repo_root")" || {
			echo "Active agent state missing for centralized devcontainer layout at $repo_root. Run 'agentbox switch --agent <name>'." >&2
			return 1
		}

		if [[ "$sync_runtime" == "true" ]]
		then
			ensure_devcontainer_runtime_files "$repo_root" "$active_agent"
		fi

		local compose_file
		while IFS= read -r compose_file
		do
			compose_files+=("$compose_file")
		done < <(emit_devcontainer_compose_files "$repo_root")
	elif cli_layered_compose_initialized "$repo_root"
	then
		local active_agent
		active_agent="$(read_active_agent "$repo_root")" || {
			echo "Active agent state missing for layered CLI compose at $repo_root. Run 'agentbox switch --agent <name>'." >&2
			return 1
		}

		if [[ "$sync_runtime" == "true" ]]
		then
			ensure_cli_agent_runtime_files "$repo_root" "$active_agent"
		fi

		local compose_file
		while IFS= read -r compose_file
		do
			compose_files+=("$compose_file")
		done < <(emit_cli_compose_files "$repo_root" "$active_agent")
	else
		echo "No layered compose layout found at $repo_root. Run 'agentbox init' first." >&2
		return 1
	fi

	local compose_args=()
	local compose_file
	for compose_file in "${compose_files[@]}"
	do
		compose_args+=(-f "$compose_file")
	done

	exec docker compose "${compose_args[@]}" "$@"
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]
then
	compose "$@"
fi
