#!/usr/bin/env python3

import argparse
import json
import os
import sys

import yaml

sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
import service_catalog  # noqa: E402

DEFAULT_SINGLE_POLICY_PATH = "/etc/mitmproxy/policy.yaml"
DEFAULT_SHARED_POLICY_PATH = "/etc/agent-sandbox/policy/user.policy.yaml"
DEFAULT_AGENT_POLICY_PATH = "/etc/agent-sandbox/policy/user.agent.policy.yaml"
DEFAULT_DEVCONTAINER_POLICY_PATH = "/etc/agent-sandbox/policy/devcontainer.policy.yaml"
KNOWN_AGENTS = {"claude", "codex", "copilot", "factory", "gemini", "opencode", "pi"}
ALLOWED_SCHEMES = ("http", "https")
DEFAULT_RULE_SCHEMES = ["http", "https"]
MISSING = object()


class RenderPolicyError(Exception):
    """Raised when render-policy refuses to render the requested policy.

    Library callers (e.g. the proxy enforcer's hot-reload path) catch this
    directly. The CLI `main()` entry point converts it to a stderr line plus
    exit code 1 so the shell-facing contract is unchanged.
    """


def fail(message):
    raise RenderPolicyError(message)


def warn(message):
    print(f"warning: {message}", file=sys.stderr)


def load_policy_file(path, required=False):
    if not path or not os.path.exists(path):
        if required:
            fail(f"Policy file not found: {path}")
        return {}

    if os.path.isdir(path):
        fail(f"Policy path is a directory, expected a file: {path}")

    if not os.path.isfile(path):
        fail(f"Policy path is not a regular file: {path}")

    with open(path, encoding="utf-8") as handle:
        data = yaml.safe_load(handle) or {}

    if not isinstance(data, dict):
        fail(f"Policy file must contain a YAML mapping: {path}")

    for field in ("services", "domains"):
        if field in data and data[field] is not None and not isinstance(data[field], list):
            fail(f"Policy field '{field}' must be a YAML list in: {path}")

    return data


def merge_other_fields(base, overlay):
    merged = dict(base)

    for key, value in overlay.items():
        if isinstance(merged.get(key), dict) and isinstance(value, dict):
            merged[key] = merge_other_fields(merged[key], value)
        elif isinstance(value, list):
            merged[key] = list(value)
        else:
            merged[key] = value

    return merged


def remove_policy_list_fields(policy):
    return {
        key: value
        for key, value in policy.items()
        if key not in ("services", "domains")
    }


def normalize_string(value, context):
    if not isinstance(value, str):
        fail(f"{context} must be a string, got {type(value).__name__}: {value!r}")

    normalized = value.strip()
    if not normalized:
        fail(f"{context} must not be empty")

    return normalized


def normalize_host_pattern(value, context):
    host = normalize_string(value, context).lower()

    if "://" in host or "/" in host or "?" in host or "#" in host:
        fail(f"{context} must be a bare host or wildcard host, got {value!r}")
    if ":" in host:
        fail(f"{context} must not include a port, got {value!r}")

    if host.startswith("*."):
        suffix = host[2:]
        if not suffix or suffix.startswith(".") or "*" in suffix:
            fail(f"{context} has an invalid wildcard host {value!r}")
        return f"*.{suffix}"

    if "*" in host:
        fail(
            f"{context} uses unsupported wildcard syntax {value!r}; "
            "only a leading '*.' wildcard is supported"
        )

    return host


def make_catch_all_rule():
    return {"schemes": list(DEFAULT_RULE_SCHEMES)}


def normalize_merge_mode(value, context):
    if value is MISSING:
        return None

    merge_mode = normalize_string(value, f"{context}.merge_mode").lower()
    if merge_mode != "replace":
        fail(
            f"{context}.merge_mode must be 'replace' when set, got {value!r}"
        )

    return merge_mode


def normalize_scheme_values(values, context, field_name):
    seen = set()

    for index, value in enumerate(values):
        scheme = normalize_string(value, f"{context}.{field_name}[{index}]").lower()
        if scheme not in ALLOWED_SCHEMES:
            fail(
                f"{context}.{field_name}[{index}] must be one of {sorted(ALLOWED_SCHEMES)}, "
                f"got {value!r}"
            )
        seen.add(scheme)

    if not seen:
        fail(f"{context}.{field_name} must not be empty")

    return [scheme for scheme in ALLOWED_SCHEMES if scheme in seen]


def normalize_method_values(values, context, field_name):
    seen = set()

    for index, value in enumerate(values):
        method = normalize_string(value, f"{context}.{field_name}[{index}]").upper()
        if any(character.isspace() for character in method):
            fail(
                f"{context}.{field_name}[{index}] must not contain whitespace, got {value!r}"
            )
        seen.add(method)

    if not seen:
        fail(f"{context}.{field_name} must not be empty")

    return sorted(seen)


def normalize_rule_schemes(rule, context):
    singular = rule.get("scheme", MISSING)
    plural = rule.get("schemes", MISSING)

    if singular is not MISSING and plural is not MISSING:
        warn(
            f"{context} supplied both 'scheme' and 'schemes'; "
            "merging them into the rendered 'schemes' list"
        )

    values = []
    saw_field = False

    if singular is not MISSING:
        saw_field = True
        values.extend(normalize_scheme_values([singular], context, "scheme"))
    if plural is not MISSING:
        saw_field = True
        if not isinstance(plural, list):
            fail(
                f"{context}.schemes must be a YAML list, got {type(plural).__name__}: {plural!r}"
            )
        values.extend(normalize_scheme_values(plural, context, "schemes"))

    if not saw_field:
        return list(DEFAULT_RULE_SCHEMES)

    seen = set(values)
    return [scheme for scheme in ALLOWED_SCHEMES if scheme in seen]


def normalize_rule_methods(rule, context):
    singular = rule.get("method", MISSING)
    plural = rule.get("methods", MISSING)

    if singular is not MISSING and plural is not MISSING:
        warn(
            f"{context} supplied both 'method' and 'methods'; "
            "merging them into the rendered 'methods' list"
        )

    values = []
    saw_field = False

    if singular is not MISSING:
        saw_field = True
        values.extend(normalize_method_values([singular], context, "method"))
    if plural is not MISSING:
        saw_field = True
        if not isinstance(plural, list):
            fail(
                f"{context}.methods must be a YAML list, got {type(plural).__name__}: {plural!r}"
            )
        values.extend(normalize_method_values(plural, context, "methods"))

    if not saw_field:
        return None

    return sorted(set(values))


def normalize_path_matcher(value, context):
    if not isinstance(value, dict):
        fail(f"{context}.path must be a YAML mapping, got {type(value).__name__}: {value!r}")

    unknown_keys = sorted(set(value) - {"exact", "prefix"})
    if unknown_keys:
        fail(f"{context}.path contains unsupported keys: {unknown_keys}")

    match_keys = [key for key in ("exact", "prefix") if key in value]
    if len(match_keys) != 1:
        fail(f"{context}.path must contain exactly one of 'exact' or 'prefix'")

    match_key = match_keys[0]
    path_value = normalize_string(value[match_key], f"{context}.path.{match_key}")
    if not path_value.startswith("/"):
        fail(
            f"{context}.path.{match_key} must start with '/', got {value[match_key]!r}"
        )

    return {match_key: path_value}


def normalize_query_matcher(value, context):
    if not isinstance(value, dict):
        fail(f"{context}.query must be a YAML mapping, got {type(value).__name__}: {value!r}")

    unknown_keys = sorted(set(value) - {"exact"})
    if unknown_keys:
        fail(f"{context}.query contains unsupported keys: {unknown_keys}")

    if "exact" not in value:
        fail(f"{context}.query must contain an 'exact' matcher")

    exact = value["exact"]
    if not isinstance(exact, dict):
        fail(
            f"{context}.query.exact must be a YAML mapping, got {type(exact).__name__}: {exact!r}"
        )

    normalized_exact = {}

    for name in sorted(exact):
        if not isinstance(name, str) or not name:
            fail(f"{context}.query.exact keys must be non-empty strings, got {name!r}")

        raw_values = exact[name]
        if isinstance(raw_values, str):
            normalized_exact[name] = [raw_values]
            continue

        if not isinstance(raw_values, list):
            fail(
                f"{context}.query.exact.{name} must be a string or YAML list of strings, "
                f"got {type(raw_values).__name__}: {raw_values!r}"
            )

        if not raw_values:
            fail(f"{context}.query.exact.{name} must not be an empty list")

        values = []
        for index, item in enumerate(raw_values):
            if not isinstance(item, str):
                fail(
                    f"{context}.query.exact.{name}[{index}] must be a string, "
                    f"got {type(item).__name__}: {item!r}"
                )
            values.append(item)
        normalized_exact[name] = sorted(values)

    return {"exact": normalized_exact}


def normalize_rule(rule, context):
    if not isinstance(rule, dict):
        fail(f"{context} must be a YAML mapping, got {type(rule).__name__}: {rule!r}")

    supported_keys = {"scheme", "schemes", "method", "methods", "path", "query"}
    unknown_keys = sorted(set(rule) - supported_keys)
    if unknown_keys:
        fail(f"{context} contains unsupported keys: {unknown_keys}")

    if not rule:
        fail(
            f"{context} must not be empty; "
            "use an explicit catch-all rule such as 'scheme: https' for host-wide trust"
        )

    normalized = {
        "schemes": normalize_rule_schemes(rule, context),
    }

    methods = normalize_rule_methods(rule, context)
    if methods is not None:
        normalized["methods"] = methods

    if "path" in rule:
        normalized["path"] = normalize_path_matcher(rule["path"], context)

    if "query" in rule:
        normalized["query"] = normalize_query_matcher(rule["query"], context)

    return normalized


def rule_identity(rule):
    return json.dumps(rule, sort_keys=True, separators=(",", ":"))


def dedupe_rules(rules):
    result = []
    seen = set()

    for rule in rules:
        identity = rule_identity(rule)
        if identity in seen:
            continue
        seen.add(identity)
        result.append(rule)

    return result


def normalize_rules(value, context):
    if not isinstance(value, list):
        fail(f"{context}.rules must be a YAML list, got {type(value).__name__}: {value!r}")

    if not value:
        fail(
            f"{context}.rules must not be empty; "
            "use a string domain entry or an explicit catch-all rule instead"
        )

    normalized = []
    for index, rule in enumerate(value):
        normalized.append(normalize_rule(rule, f"{context}.rules[{index}]"))

    return dedupe_rules(normalized)


def make_host_record(host, rules=None):
    return {
        "host": host,
        "rules": list(rules or [make_catch_all_rule()]),
    }


def normalize_domain_entry(entry, context):
    if isinstance(entry, str):
        host = normalize_host_pattern(entry, context)
        return make_host_record(host), None

    if not isinstance(entry, dict):
        fail(
            f"{context} must be either a string host or a YAML mapping, "
            f"got {type(entry).__name__}: {entry!r}"
        )

    supported_keys = {"host", "merge_mode", "rules"}
    unknown_keys = sorted(set(entry) - supported_keys)
    if unknown_keys:
        fail(f"{context} contains unsupported keys: {unknown_keys}")

    if "host" not in entry:
        fail(f"{context} must contain 'host'")
    if "rules" not in entry:
        fail(
            f"{context} must contain 'rules'; "
            "use a string domain entry for a catch-all host allow"
        )

    host = normalize_host_pattern(entry["host"], f"{context}.host")
    merge_mode = normalize_merge_mode(entry.get("merge_mode", MISSING), context)
    rules = normalize_rules(entry["rules"], context)
    return make_host_record(host, rules), merge_mode


def host_sort_key(record, original_index):
    host = record["host"]
    if host.startswith("*."):
        return (1, -len(host[2:]), original_index)
    return (0, 0, original_index)


def make_render_state():
    return {
        "hosts": {},
        "order": [],
        "other": {},
        "service_rules": {},
    }


def apply_host_record(state, record, merge_mode=None):
    host = record["host"]

    if host in state["hosts"]:
        if merge_mode == "replace":
            state["hosts"][host] = {
                "host": host,
                "rules": list(record["rules"]),
            }
            return

        state["hosts"][host]["rules"] = dedupe_rules(
            state["hosts"][host]["rules"] + list(record["rules"])
        )
        return

    state["order"].append(host)
    state["hosts"][host] = {
        "host": host,
        "rules": list(record["rules"]),
    }


def discard_service_contributions(state, service_name):
    contributions = state["service_rules"].pop(service_name, None)
    if not contributions:
        return

    for host, identities in contributions.items():
        record = state["hosts"].get(host)
        if record is None:
            continue
        identity_set = set(identities)
        remaining = [
            rule for rule in record["rules"]
            if rule_identity(rule) not in identity_set
        ]
        if remaining:
            state["hosts"][host]["rules"] = remaining
        else:
            del state["hosts"][host]
            state["order"] = [existing for existing in state["order"] if existing != host]


def apply_service_expansion(state, expansion):
    service_name = expansion["name"]
    if expansion["merge_mode"] == "replace":
        discard_service_contributions(state, service_name)

    contributions = state["service_rules"].setdefault(service_name, {})
    for record in expansion["records"]:
        host = record["host"]
        apply_host_record(state, record)
        host_contributions = contributions.setdefault(host, [])
        for rule in record["rules"]:
            host_contributions.append(rule_identity(rule))


def apply_policy_layer(state, policy, context):
    state["other"] = merge_other_fields(
        state["other"],
        remove_policy_list_fields(policy),
    )

    for index, service_value in enumerate(policy.get("services") or []):
        service_context = f"{context}.services[{index}]"
        expansion = service_catalog.expand_service_entry(
            service_value,
            service_context,
            fail,
        )
        apply_service_expansion(state, expansion)

    for index, domain_value in enumerate(policy.get("domains") or []):
        record, merge_mode = normalize_domain_entry(
            domain_value,
            f"{context}.domains[{index}]",
        )
        apply_host_record(state, record, merge_mode)


def finalize_render_state(state):
    rendered = dict(state["other"])
    ordered_records = [state["hosts"][host] for host in state["order"]]
    order_by_host = {host: index for index, host in enumerate(state["order"])}
    rendered["domains"] = sorted(
        ordered_records,
        key=lambda record: host_sort_key(record, order_by_host[record["host"]]),
    )
    return rendered


def render_layered_policy(active_agent):
    shared_policy_path = os.getenv("AGENTBOX_SHARED_POLICY_PATH", DEFAULT_SHARED_POLICY_PATH)
    agent_policy_path = os.getenv("AGENTBOX_AGENT_POLICY_PATH", DEFAULT_AGENT_POLICY_PATH)
    devcontainer_policy_path = os.getenv("AGENTBOX_DEVCONTAINER_POLICY_PATH", DEFAULT_DEVCONTAINER_POLICY_PATH)

    state = make_render_state()
    apply_policy_layer(state, {"services": [active_agent], "domains": []}, "baseline")
    apply_policy_layer(state, load_policy_file(shared_policy_path), shared_policy_path)
    apply_policy_layer(state, load_policy_file(agent_policy_path), agent_policy_path)
    apply_policy_layer(state, load_policy_file(devcontainer_policy_path), devcontainer_policy_path)
    return finalize_render_state(state)


def render_single_policy():
    policy_source_path = os.getenv("AGENTBOX_POLICY_SOURCE_PATH", DEFAULT_SINGLE_POLICY_PATH)
    state = make_render_state()
    apply_policy_layer(
        state,
        load_policy_file(policy_source_path, required=True),
        policy_source_path,
    )
    return finalize_render_state(state)


def render_policy():
    active_agent = os.getenv("AGENTBOX_ACTIVE_AGENT", "").strip()
    if active_agent:
        if active_agent not in KNOWN_AGENTS:
            fail(
                "Unknown agent in AGENTBOX_ACTIVE_AGENT: "
                f"{active_agent!r} (expected one of {sorted(KNOWN_AGENTS)})"
            )
        return render_layered_policy(active_agent)
    return render_single_policy()


def main():
    parser = argparse.ArgumentParser(description="Render the effective proxy policy")
    parser.add_argument("--output", help="Write rendered YAML to this path instead of stdout")
    args = parser.parse_args()

    try:
        rendered_policy = render_policy()
    except RenderPolicyError as error:
        print(str(error), file=sys.stderr)
        sys.exit(1)

    rendered_yaml = yaml.safe_dump(rendered_policy, sort_keys=False)

    if args.output:
        output_dir = os.path.dirname(args.output)
        if output_dir:
            os.makedirs(output_dir, exist_ok=True)
        with open(args.output, "w", encoding="utf-8") as handle:
            handle.write(rendered_yaml)
        return

    sys.stdout.write(rendered_yaml)


if __name__ == "__main__":
    main()
